rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function isOwner(uid) {
      return signedIn() && request.auth.uid == uid;
    }

    function isAdmin() {
      return signedIn()
        && exists(/databases/$(database)/documents/users/$(request.auth.uid))
        && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == "admin";
    }

    function matchIsOpen(matchId) {
      return exists(/databases/$(database)/documents/matches/$(matchId))
        && get(/databases/$(database)/documents/matches/$(matchId)).data.status != "finished";
    }

    match /users/{userId} {
      allow read: if signedIn();

      allow create: if isOwner(userId)
        && request.resource.data.role == "player"
        && request.resource.data.email == request.auth.token.email;

      allow update: if isAdmin()
        || (isOwner(userId)
          && request.resource.data.role == resource.data.role
          && request.resource.data.email == resource.data.email);

      allow delete: if isAdmin();
    }

    match /matches/{matchId} {
      allow read: if signedIn();
      allow create, update, delete: if isAdmin();
    }

    match /bets/{betId} {
      allow read: if signedIn();

      allow create: if signedIn()
        && request.resource.data.userId == request.auth.uid
        && request.resource.data.matchId is string
        && matchIsOpen(request.resource.data.matchId);

      allow update: if signedIn()
        && resource.data.userId == request.auth.uid
        && request.resource.data.userId == request.auth.uid
        && request.resource.data.matchId == resource.data.matchId
        && matchIsOpen(resource.data.matchId);

      allow delete: if isAdmin()
        || (signedIn()
          && resource.data.userId == request.auth.uid
          && matchIsOpen(resource.data.matchId));
    }
  }
}
